# MeetScribe Backend Environment Variables

# Server
PORT=3456
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://meetscribe:meetscribe@localhost:5432/meetscribe

# Token Validation
# The secret key used to validate issued access tokens
TOKEN_VALIDATION_SECRET=change-me-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3456/api/auth/google/callback

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info