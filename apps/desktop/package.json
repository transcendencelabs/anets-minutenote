{
  "name": "@meetscribe/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev": "npm run build:main && cross-env NODE_ENV=development electron dist/main/main.js",
    "rebuild:native": "electron-rebuild -w better-sqlite3",
    "postinstall": "electron-rebuild -w better-sqlite3",
    "dev:renderer": "vite",
    "test": "jest --config jest.config.js",
    "lint": "eslint src",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@meetscribe/logging": "*",
    "@meetscribe/providers": "*",
    "@meetscribe/scheduler": "*",
    "@meetscribe/shared": "*",
    "@meetscribe/storage": "*",
    "@meetscribe/transcription": "*",
    "@types/dotenv": "^6.1.1",
    "axios": "^1.7.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
